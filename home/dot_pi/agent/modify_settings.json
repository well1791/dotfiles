#!/bin/sh
# Modify pi settings.json: preserve lastChangelogVersion from the target,
# apply all other settings from the source definition below.

set -e

# Desired settings (everything except lastChangelogVersion)
SOURCE_JSON='{
  "defaultProvider": "github-copilot",
  "defaultModel": "claude-opus-4.6",
  "defaultThinkingLevel": "medium",
  "skills": [],
  "packages": [
    "npm:pi-subagents",
    "npm:pi-intercom",
    "npm:pi-btw",
    "npm:@mrclrchtr/supi-extras",
    "npm:@a5c-ai/babysitter-pi",
    "npm:pi-hermes-memory",
    "npm:glimpseui",
    "npm:pi-smart-fetch",
    "npm:pi-smart-web-search",
    "npm:pi-mcp-extension",
    "npm:pi-lean-ctx",
    "git:github.com/obra/superpowers"
  ],
  "npmCommand": [
    "bun"
  ],
  "hideThinkingBlock": true,
  "treeFilterMode": "no-tools",
  "branchSummary": {
    "skipPrompt": true
  },
  "enabledModels": [
    "github-copilot/claude-haiku-4.5",
    "github-copilot/claude-opus-4.6",
    "github-copilot/claude-sonnet-4.5",
    "github-copilot/gpt-5-mini",
    "github-copilot/gemini-2.5-pro",
    "opencode/big-pickle"
  ],
  "theme": "dark",
  "quietStartup": true,
  "doubleEscapeAction": "tree",
  "enableSkillCommands": true
}'

# Read current target from stdin
TARGET_JSON="$(cat)"

if [ -z "$TARGET_JSON" ] || [ "$TARGET_JSON" = "{}" ]; then
    # No existing target — use a default version
    echo "$SOURCE_JSON" | jq --arg v "0.0.0" '{lastChangelogVersion: $v} + .'
else
    # Preserve lastChangelogVersion from the existing target
    CURRENT_VERSION="$(echo "$TARGET_JSON" | jq -r '.lastChangelogVersion // "0.0.0"')"
    printf '%s' "$(echo "$SOURCE_JSON" | jq --arg v "$CURRENT_VERSION" '{lastChangelogVersion: $v} + .')"
fi
