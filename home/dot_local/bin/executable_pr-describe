#!/usr/bin/env bash
set -euo pipefail

# pr-describe - Generate PR description from git diff
# Part of the pr-workflows package

show_usage() {
    cat <<EOF
Usage: pr-describe TARGET_BRANCH

Generate a PR description from git diff and output the file path.

Arguments:
  TARGET_BRANCH    Required. The base/target branch to compare against.
                   Example: origin/dev, origin/main

Output:
  Prints the path to the generated markdown file (e.g., /tmp/pr-description-12345678.md)
  Use in other commands: DESC_FILE=\$(pr-describe origin/dev)

Exit Codes:
  0    Success - description generated and file path printed
  1    Validation error - git repo, branch, or commits issue
  2    Usage error - missing or invalid arguments

Examples:
  # Generate description comparing to origin/dev
  pr-describe origin/dev

  # Generate description comparing to origin/main
  pr-describe origin/main

  # Capture output for use in other commands
  DESC_FILE=\$(pr-describe origin/dev)
  cat "\$DESC_FILE"

Requirements:
  - Git repository with commits ahead of target branch
  - pi CLI (AI coding assistant)

EOF
}

# Parse arguments
if [[ $# -eq 0 ]]; then
    echo "Error: TARGET_BRANCH argument required" >&2
    echo "" >&2
    show_usage >&2
    exit 2
fi

if [[ "$1" == "--help" || "$1" == "-h" ]]; then
    show_usage
    exit 0
fi

TARGET_BRANCH="$1"

# Validate we're in a git repository
if ! git rev-parse --git-dir > /dev/null 2>&1; then
    echo "Error: Not in a git repository" >&2
    exit 1
fi

# Validate target branch exists
if ! git rev-parse --verify "$TARGET_BRANCH" > /dev/null 2>&1; then
    echo "Error: Branch '$TARGET_BRANCH' not found" >&2
    echo "Hint: Use format 'origin/branch-name' for remote branches" >&2
    exit 1
fi

# Get current branch
CURRENT_BRANCH=$(git branch --show-current)
if [[ -z "$CURRENT_BRANCH" ]]; then
    echo "Error: Not on a branch (detached HEAD?)" >&2
    exit 1
fi

# Validate current branch has commits ahead of target
COMMITS_AHEAD=$(git rev-list "$TARGET_BRANCH..HEAD" --count 2>/dev/null || echo "0")
if [[ "$COMMITS_AHEAD" -eq 0 ]]; then
    echo "Error: No commits ahead of $TARGET_BRANCH" >&2
    echo "" >&2
    echo "Nothing to describe. Branch is up-to-date or already merged." >&2
    exit 1
fi

# Generate temp file with random 8-digit number
OUTPUT_FILE=$(mktemp /tmp/pr-description-XXXXXXXX.md)

echo "Generating PR description..." >&2
echo "Target branch: $TARGET_BRANCH" >&2
echo "Current branch: $CURRENT_BRANCH" >&2
echo "Commits ahead: $COMMITS_AHEAD" >&2
echo "" >&2

# Invoke pi with the pr-describe agent
# We'll use pi in non-interactive mode with a task that includes the parameters
PI_CMD=(
    pi -p
    --no-session
    --system-prompt "You are a PR description generator. Generate a structured PR description from git diff and write it to the specified file."
    "Generate a PR description by analyzing the git diff between $TARGET_BRANCH and HEAD. 

Target branch: $TARGET_BRANCH
Output file: $OUTPUT_FILE

Steps:
1. Run: git diff $TARGET_BRANCH..HEAD --stat
2. Run: git diff $TARGET_BRANCH..HEAD
3. Generate a markdown description with exactly two sections:

## Overview
[What was broken or needed - the problem]
[Why it happened - root cause in 1-2 sentences]
[What the fix/feature does - the solution conceptually]

## What this PR does?
1. **Title of change** — Description of what changed, why, and how it works. Reference relevant identifiers inline.
2. **Title of change** — Description of the second change...

Format rules:
- Use **bold** for change titles
- Use \`single backticks\` for inline code: function names, file names, variables, types
- NO fenced code blocks — describe changes verbally
- NO copy-pasted code snippets — describe in words
- Keep descriptions concise and decision-focused
- Focus on WHY changes were made, not just WHAT changed

4. Write the generated description to: $OUTPUT_FILE

After writing, report: 'Description written to $OUTPUT_FILE'"
)

# Run the command
if "${PI_CMD[@]}" > /dev/null 2>&1; then
    # Verify file was created and has content
    if [[ -f "$OUTPUT_FILE" && -s "$OUTPUT_FILE" ]]; then
        echo "✅ Description generated successfully" >&2
        echo "$OUTPUT_FILE"
        exit 0
    else
        echo "Error: Description file was not created or is empty" >&2
        exit 1
    fi
else
    echo "Error: Failed to generate PR description" >&2
    exit 1
fi
