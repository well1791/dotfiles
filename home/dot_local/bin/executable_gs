#!/bin/sh
# Wrapper for gs to remind about using gst for git status

# Check if user really wants Ghostscript
if [ "$1" = "--ghostscript" ]; then
    shift
    exec /usr/bin/gs "$@"
fi

# Colors (always enabled since we know ghostty supports them)
RED='\033[0;31m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
BOLD='\033[1m'
NC='\033[0m'

printf "\n"
printf "%b%b⚠️  Hold up!%b\n" "$BOLD" "$RED" "$NC"
printf "\n"
printf "%bYou typed:%b %bgs%b\n" "$YELLOW" "$NC" "$RED" "$NC"
printf "%bDid you mean:%b %bgst%b (git status)\n" "$YELLOW" "$NC" "$BLUE" "$NC"
printf "\n"
printf "If you actually need Ghostscript, use: %bgs --ghostscript%b\n" "$BLUE" "$NC"
printf "\n"

exit 1
