#!/bin/sh
# Unified update script for all package managers and tools
# Updates: system packages, mise, uv, rust, nix, devenv, bun, engram, pi,
#          vortix, tealdeer cache, flatpak

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Print colored status
print_status() {
    printf "${BLUE}==>${NC} ${GREEN}%s${NC}\n" "$1"
}

print_error() {
    printf "${RED}Error:${NC} %s\n" "$1" >&2
}

print_warning() {
    printf "${YELLOW}Warning:${NC} %s\n" "$1"
}

# Track if any updates failed
FAILED=0

# ============================================================================
# 1. System Packages (pacman/apt/dnf/apk)
# ============================================================================
print_status "Updating system packages..."

if [ -f /etc/os-release ]; then
    . /etc/os-release
    
    case "$ID" in
        arch|cachyos|manjaro|endeavouros)
            if command -v paru >/dev/null 2>&1; then
                paru -Syu --noconfirm || FAILED=$((FAILED + 1))
            elif command -v yay >/dev/null 2>&1; then
                yay -Syu --noconfirm || FAILED=$((FAILED + 1))
            else
                sudo pacman -Syu --noconfirm || FAILED=$((FAILED + 1))
            fi
            ;;
        ubuntu|debian|linuxmint|pop)
            sudo apt-get update && sudo apt-get upgrade -y || FAILED=$((FAILED + 1))
            ;;
        fedora|rhel|centos|rocky|almalinux)
            sudo dnf upgrade -y || FAILED=$((FAILED + 1))
            ;;
        alpine)
            sudo apk update && sudo apk upgrade || FAILED=$((FAILED + 1))
            ;;
        *)
            if echo "$ID_LIKE" | grep -q "arch"; then
                if command -v paru >/dev/null 2>&1; then
                    paru -Syu --noconfirm || FAILED=$((FAILED + 1))
                elif command -v yay >/dev/null 2>&1; then
                    yay -Syu --noconfirm || FAILED=$((FAILED + 1))
                else
                    sudo pacman -Syu --noconfirm || FAILED=$((FAILED + 1))
                fi
            elif echo "$ID_LIKE" | grep -q "debian"; then
                sudo apt-get update && sudo apt-get upgrade -y || FAILED=$((FAILED + 1))
            elif echo "$ID_LIKE" | grep -q "rhel\|fedora"; then
                sudo dnf upgrade -y || FAILED=$((FAILED + 1))
            else
                print_warning "Unknown distribution, skipping system package updates"
            fi
            ;;
    esac
fi

# ============================================================================
# 2. mise (runtime manager)
# ============================================================================
if command -v mise >/dev/null 2>&1; then
    print_status "Updating mise..."
    mise self-update || FAILED=$((FAILED + 1))
    
    print_status "Updating mise-managed runtimes..."
    mise upgrade || print_warning "No mise runtime upgrades available"
else
    print_warning "mise not found, skipping"
fi

# ============================================================================
# 3. uv (Python package manager)
# ============================================================================
if command -v uv >/dev/null 2>&1; then
    print_status "Updating uv..."
    uv self update || FAILED=$((FAILED + 1))
    print_status "Updating uv tools (sqlit, etc.)..."
    uv tool upgrade --all || FAILED=$((FAILED + 1))
else
    print_warning "uv not found, skipping"
fi

# ============================================================================
# 4. Rust (rustup)
# ============================================================================
if command -v rustup >/dev/null 2>&1; then
    print_status "Updating Rust toolchain..."
    rustup update || FAILED=$((FAILED + 1))
else
    print_warning "rustup not found, skipping"
fi

# ============================================================================
# 5. Nix packages
# ============================================================================
if command -v nix >/dev/null 2>&1; then
    print_status "Updating Nix channels..."
    nix-channel --update || print_warning "Could not update Nix channels (might need sudo)"
    
    print_status "Upgrading Nix packages..."
    nix-env -u || print_warning "Could not upgrade Nix packages"

else
    print_warning "nix not found, skipping"
fi

# ============================================================================
# 6. devenv
# ============================================================================
if command -v devenv >/dev/null 2>&1; then
    print_status "Updating devenv..."
    # Run in home directory to avoid creating .devenv/ in unintended locations
    (cd "$HOME" && devenv update) || print_warning "devenv update failed (this is sometimes expected)"
else
    print_warning "devenv not found, skipping"
fi

# ============================================================================
# 7. Bun (if installed)
# ============================================================================
if command -v bun >/dev/null 2>&1; then
    print_status "Updating Bun..."
    bun upgrade || FAILED=$((FAILED + 1))
else
    print_warning "bun not found, skipping"
fi

# ============================================================================
# 8. engram (AI task manager)
# ============================================================================
if command -v engram >/dev/null 2>&1; then
    print_status "Updating engram..."
    
    # Detect architecture
    ARCH=$(uname -m)
    case "$ARCH" in
        x86_64)   ARCH_NAME="amd64" ;;
        aarch64|arm64) ARCH_NAME="arm64" ;;
        *)        ARCH_NAME="" ;;
    esac
    
    if [ -z "$ARCH_NAME" ]; then
        print_warning "Unsupported architecture for engram: $ARCH"
    else
        LATEST_VERSION=$(curl -sf https://api.github.com/repos/Gentleman-Programming/engram/releases/latest | grep '"tag_name"' | sed -E 's/.*"([^"]+)".*/\1/')
        
        if [ -z "$LATEST_VERSION" ]; then
            print_warning "Could not fetch latest engram version"
        else
            VERSION_NUM=$(echo "$LATEST_VERSION" | sed 's/^v//')
            DOWNLOAD_URL="https://github.com/Gentleman-Programming/engram/releases/download/${LATEST_VERSION}/engram_${VERSION_NUM}_linux_${ARCH_NAME}.tar.gz"
            TMP_DIR=$(mktemp -d)
            
            if curl -sfL -o "$TMP_DIR/engram.tar.gz" "$DOWNLOAD_URL" &&
               tar -xzf "$TMP_DIR/engram.tar.gz" -C "$TMP_DIR" &&
               [ -f "$TMP_DIR/engram" ]; then
                mv "$TMP_DIR/engram" "$HOME/.local/bin/engram"
                chmod +x "$HOME/.local/bin/engram"
                print_status "engram updated to $LATEST_VERSION"
            else
                print_warning "Could not download/extract engram"
                FAILED=$((FAILED + 1))
            fi
            
            rm -rf "$TMP_DIR"
        fi
    fi
else
    print_warning "engram not found, skipping"
fi

# ============================================================================
# 9. Vortix (VPN TUI)
# ============================================================================
if command -v vortix >/dev/null 2>&1; then
    print_status "Updating vortix..."
    vortix update || print_warning "vortix update failed"
else
    print_warning "vortix not found, skipping"
fi

# ============================================================================
# 10. Tealdeer cache
# ============================================================================
if command -v tldr >/dev/null 2>&1; then
    print_status "Updating tealdeer cache..."
    tldr --update || print_warning "Could not update tealdeer cache"
fi

# ============================================================================
# 11. Flatpak
# ============================================================================
if command -v flatpak >/dev/null 2>&1; then
    print_status "Updating Flatpak packages..."
    flatpak update -y --noninteractive || print_warning "Flatpak update failed"
fi

# ============================================================================
# 12. pi coding agent (if installed via bun)
# ============================================================================
if command -v pi >/dev/null 2>&1 && command -v bun >/dev/null 2>&1; then
    # Check if pi is installed via bun (not a standalone binary)
    PI_PATH=$(command -v pi)
    if file "$PI_PATH" | grep -q "symbolic link\|text\|script"; then
        print_status "Updating pi coding agent..."
        bun install -g @earendil-works/pi-coding-agent || FAILED=$((FAILED + 1))
    fi
fi

# ============================================================================
# Summary
# ============================================================================
echo ""
if [ $FAILED -eq 0 ]; then
    print_status "✓ All updates completed successfully!"
else
    print_error "$FAILED update(s) failed. Check the output above for details."
    exit 1
fi
