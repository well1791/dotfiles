#!/bin/sh
# Update pi and commit the version bump in settings.json.tmpl to dotfiles.
# Idempotent: safe to re-run. Stops if dotfiles repo has staged files.

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

die() { printf "${RED}Error:${NC} %s\n" "$1" >&2; exit 1; }
info() { printf "${GREEN}==>${NC} %s\n" "$1"; }
warn() { printf "${YELLOW}Warning:${NC} %s\n" "$1"; }

SETTINGS="$HOME/.pi/agent/settings.json"
CHEZMOI_SOURCE="$(chezmoi source-path)"
GIT_ROOT=$(git -C "$CHEZMOI_SOURCE" rev-parse --show-toplevel)
# The source is a template file, not a plain copy
SOURCE_SETTINGS="$CHEZMOI_SOURCE/dot_pi/agent/settings.json.tmpl"
RELATIVE_SETTINGS="${SOURCE_SETTINGS#$GIT_ROOT/}"

[ -f "$SOURCE_SETTINGS" ] || die "Template source not found: $SOURCE_SETTINGS"

# --- Guard: no staged files in dotfiles repo ---
staged=$(git -C "$GIT_ROOT" diff --cached --name-only)
if [ -n "$staged" ]; then
    die "Dotfiles repo has staged files. Unstage or commit them first:\n$staged"
fi

# --- Get old version from template source ---
old_version=$(grep -o '"lastChangelogVersion": *"[^"]*"' "$SOURCE_SETTINGS" | head -1 | sd '.*: *"([^"]*)"' '$1')

# --- Run pi update ---
info "Updating pi..."
pi update

# --- Get new version from rendered settings ---
if [ ! -f "$SETTINGS" ]; then
    die "Settings file not found after update: $SETTINGS"
fi
new_version=$(grep -o '"lastChangelogVersion": *"[^"]*"' "$SETTINGS" | head -1 | sd '.*: *"([^"]*)"' '$1')

if [ "$old_version" = "$new_version" ]; then
    info "No version change — already up to date (v${new_version})."
    exit 0
fi

# --- Update version in template source (preserves template variables) ---
info "Updating version in template: ${old_version} -> ${new_version}"
sd -F "\"lastChangelogVersion\": \"${old_version}\"" "\"lastChangelogVersion\": \"${new_version}\"" "$SOURCE_SETTINGS"

# --- Verify chezmoi still renders correctly ---
chezmoi_status=$(chezmoi status "$SETTINGS" 2>/dev/null || true)
if [ -n "$chezmoi_status" ]; then
    warn "Chezmoi still reports drift after version update. Other fields may have changed."
    warn "Review with: chezmoi diff $SETTINGS"
fi

# --- Stage and commit ---
git -C "$GIT_ROOT" add -- "$RELATIVE_SETTINGS"

if git -C "$GIT_ROOT" diff --cached --quiet -- "$RELATIVE_SETTINGS"; then
    info "No changes to commit — already up to date (v${new_version})."
    exit 0
fi

commit_msg="chore(pi): update pi ${old_version} -> ${new_version}"
git -C "$GIT_ROOT" commit -m "$commit_msg" -- "$RELATIVE_SETTINGS"
info "Committed: $commit_msg"
