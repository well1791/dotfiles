{{ template "install-header.sh.tmpl" . }}
# Install essential CLI tools (modern replacements)
# Tools: helix, ripgrep, yazi, bat, dust, duf, eza, glow, sd, serpl, just, tealdeer, pass
{{- $tools := dict
    "helix" (list "helix" "hx")
    "ripgrep" (list "rg")
    "yazi" (list "yazi")
    "bat" (list "bat")
    "dust" (list "dust")
    "duf" (list "duf")
    "eza" (list "eza")
    "glow" (list "glow")
    "sd" (list "sd")
    "serpl" (list "serpl")
    "just" (list "just")
    "tealdeer" (list "tldr")
    "pass" (list "pass")
}}

# Check which tools are missing
MISSING=""
{{- range $pkg, $cmds := $tools }}
{{- $primary := index $cmds 0 }}
if ! check_any_command {{ join " " $cmds }}; then
    MISSING="$MISSING {{ $pkg }}"
fi
{{- end }}

# Exit early if all installed
if [ -z "$MISSING" ]; then
    log_success "All CLI tools already installed"
    exit 0
fi

log_info "Installing CLI tools:$MISSING"
install_packages $MISSING

# Verify installations
echo ""
log_info "Verifying installations:"
{{- range $pkg, $cmds := $tools }}
{{- $primary := index $cmds 0 }}
if check_any_command {{ join " " $cmds }}; then
    log_success "{{ $pkg }}" "$(get_version {{ $primary }})"
else
    log_error "{{ $pkg }}: not found"
fi
{{- end }}
