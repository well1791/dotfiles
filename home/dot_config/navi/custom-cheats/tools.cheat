% rmpc, mpd, music

# Launch rmpc TUI
rmpc

# Add YouTube music URL
rmpc addyt <url>

# Show current config
rmpc config

# Save config to file
rmpc config > ~/.config/rmpc/config.ron

% update-all, maintenance

# Update all self-updating tools
update-all

% mkp, project, scaffold

# Create new project from template
mkp
