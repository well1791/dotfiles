% rmux, session, multiplexer, terminal

# Start a new named session
rmux new -s <session_name>

# List all sessions
rmux ls

# Attach to an existing session
rmux attach -t <session>

# Kill a session
rmux kill-session -t <session>

# Reload config (inside rmux)
rmux source-file ~/.config/rmux/rmux.conf

# Show all custom root keybindings
rmux list-keys -T root | grep -v Mouse

# Show copy-mode-vi keybindings
rmux list-keys -T copy-mode-vi

$ session: rmux ls -F '#S' 2>/dev/null
