# Main theme
theme = Ghostty Default Style Dark

# Mouse actions
copy-on-select = clipboard
right-click-action = paste

# Main theme
font-size = 16
# window-padding-x = 16

# UI styles
scrollbar = never
gtk-wide-tabs = false
window-decoration = none

# Default behavior
maximize = true

# Custom css
gtk-custom-css = tab-style.css

# Unbind keybindings for zellij to handle
keybind = ctrl+shift+t=unbind
keybind = ctrl+page_up=unbind
keybind = ctrl+page_down=unbind
keybind = ctrl+tab=unbind
keybind = ctrl+shift+tab=unbind

# Paste with ctrl+v instead of ctrl+shift+v
keybind = ctrl+shift+v=unbind
keybind = ctrl+v=paste_from_clipboard
