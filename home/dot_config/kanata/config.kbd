  ;;                   | | | | |    --     | | | | |
  ;;                   | |*| | |    --     | | |*| |
  ;;                       |*|*|    --     |*|*|
  ;;(ch_bil ch_bml ch_hrl) ???             (ch_bir ch_bmr ch_hrr) ???

  ;;----------------------------------------------------------------------
  ;;                  |*|*|*|*|     --     |*|*|*|*|
  ;;                  | | | | |     --     | | | | |
  (ch_tpl ch_trl ch_tml ch_til) caps       (ch_tir ch_tmr ch_trr ch_tpr) caps
)

(defchords CH_NS $chord_timeout
  ;; NUMBER CHORDS
                    (ch_ns_ti) 6    (ch_ns_tm) 8      (ch_ns_tr) 0    (ch_ns_tp) S-8
  (ch_ns_si) S-2    (ch_ns_hi) 1    (ch_ns_hm) 3      (ch_ns_hr) 5
                    (ch_ns_bi) =    (ch_ns_bm) S-+
  (ch_ns_hpl) @ns_nav_quote_l
  (ch_ns_hpr) @ns_nav_quote_r

  ;; --------------------------------------------------------
  ;;                  | | | | |     --     | | | | |
  ;;                  | | |*|*|     --     |*|*| | |
  (ch_ns_hi  ch_ns_hm) 2

  ;;                  | | | | |     --     | | | | |
  ;;                  | |*|*| |     --     | |*|*| |
  (ch_ns_hm  ch_ns_hr) 4

  ;;                  | | |*|*|     --     |*|*| | |
  ;;                  | | | | |     --     | | | | |
  (ch_ns_ti  ch_ns_tm) 7

  ;;                  | |*|*| |     --     | |*|*| |
  ;;                  | | | | |     --     | | | | |
  (ch_ns_tm  ch_ns_tr) 9

  ;;                  | | | | |     --     | | | | |
  ;;                  | |*| |*|     --     |*| |*| |
  (ch_ns_hr ch_ns_hi) S-9 ;; (

  ;;                  | |*| |*|     --     |*| |*| |
  ;;                  | | | | |     --     | | | | |
  (ch_ns_tr ch_ns_ti) S-0 ;; )

  ;;                  | | | | |     --     | | | | |
  ;;                  |*| | |*|     --     |*| | |*|
  (ch_ns_hpl ch_ns_hi) [
  (ch_ns_hpr ch_ns_hi) [

  ;;                  |*| | |*|     --     |*| | |*|
  ;;                  | | | | |     --     | | | | |
  (ch_ns_tp ch_ns_ti) ]

  ;;                  | | | | |     --     | | | | |
  ;;                  | | |*| |     --     | |*| | |
  ;;                      | |*|     --     |*| |
  (ch_ns_hm ch_ns_bi) S-[ ;; {

  ;;                  | | | | |     --     | | | | |
  ;;                  | |*| | |     --     | | |*| |
  ;;                      |*| |     --     | |*|
  (ch_ns_hr ch_ns_bm) S-] ;; }

  ;;                  | | | | |     --     | | | | |
  ;;                  | |*| | |     --     | | |*| |
  ;;                      | |*|     --     |*| |
  (ch_ns_hr ch_ns_bi) S-, ;; <

  ;;                  | | | | |     --     | | | | |
  ;;                  |*| | | |     --     | | | |*|
  ;;                      | |*|     --     |*| |
  (ch_ns_hpl ch_ns_bi) S-. ;; >
  (ch_ns_hpr ch_ns_bi) S-. ;; >

  ;;                  | | |*| |     --     | |*| | |
  ;;                  | | | |*|     --     |*| | | |
  (ch_ns_hi ch_ns_tm) .

  ;;                  | | |*| |     --     | |*| | |
  ;;                  | |*| | |     --     | | |*| |
  (ch_ns_hr ch_ns_tm) ,

  ;;                  | |*| | |     --     | | |*| |
  ;;                  | | | |*|     --     |*| | | |
  (ch_ns_tr ch_ns_hi) /

  ;;                  | | | |*|     --     |*| | | |
  ;;                  | |*| | |     --     | | |*| |
  (ch_ns_hr ch_ns_ti) \

  ;;                  |*| | | |     --     | | | |*|
  ;;                  | | | |*|     --     |*| | | |
  (ch_ns_tp ch_ns_hi) -

  ;;                  | | | |*|     --     |*| | | |
  ;;                  |*| | | |     --     | | | |*|
  (ch_ns_hpl ch_ns_ti) S--
  (ch_ns_hpr ch_ns_ti) S--

  ;;                  | | | | |     --     | | | | |
  ;;                  |*|*| | |     --     | | |*|*|
  (ch_ns_hpl ch_ns_hr) S-'
  (ch_ns_hpr ch_ns_hr) S-'

  ;;                  |*|*| | |     --     | | |*|*|
  ;;                  | | | | |     --     | | | | |
  (ch_ns_tp ch_ns_tr) S-5

  ;; --------------------------------------------------------
  ;;                  | | | | |     --     | | | | |
  ;;                  | |*|*|*|     --     |*|*|*| |
  (ch_ns_hr ch_ns_hm ch_ns_hi) S-1

  ;;                  | |*|*|*|     --     |*|*|*| |
  ;;                  | | | | |     --     | | | | |
  (ch_ns_tr ch_ns_tm ch_ns_ti) S-/

  ;;                  | | |*| |     --     | |*| | |
  ;;                  | |*| |*|     --     |*| |*| |
  (ch_ns_hr ch_ns_tm ch_ns_hi) ;

  ;;                  | |*|*| |     --     | |*|*| |
  ;;                  | | | |*|     --     |*| | | |
  (ch_ns_tr ch_ns_tm ch_ns_hi) S-;

  ;;                  | |*| | |     --     | | |*| |
  ;;                  | | |*|*|     --     |*|*| | |
  (ch_ns_tr ch_ns_hm ch_ns_hi) S-7

  ;;                  | | |*|*|     --     |*|*| | |
  ;;                  | |*| | |     --     | | |*| |
  (ch_ns_hr ch_ns_tm ch_ns_ti) S-\

  ;;                  | | | | |     --     | | | | |
  ;;                  |*|*|*| |     --     | |*|*|*|
  (ch_ns_hpl ch_ns_hr ch_ns_hm) `
  (ch_ns_hpr ch_ns_hr ch_ns_hm) `

  ;;                  |*|*|*| |     --     | |*|*|*|
  ;;                  | | | | |     --     | | | | |
  (ch_ns_tp ch_ns_tr ch_ns_tm) S-`

  ;; --------------------------------------------------------
  ;;                  | | | | |     --     | | | | |
  ;;                  | | | | |     --     | | | | |
  ;;                      |*|*|     --     |*|*|
  (ch_ns_bm ch_ns_bi) S-3 

  ;;                  | | | | |     --     | | | | |
  ;;                  | |*|*| |     --     | |*|*| |
  ;;                      | |*|     --     |*| |
  (ch_ns_hr ch_ns_hm ch_ns_bi) S-4

  ;;                  | | | | |     --     | | | | |
  ;;                  | |*| | |     --     | | |*| |
  ;;                      |*|*|     --     |*|*|
  (ch_ns_hr ch_ns_bm ch_ns_bi) S-6
)

(defchords CH_FF $chord_timeout
  ;; NUMBER CHORDS
  (ch_ff_ti) f6   (ch_ff_tm) f8   (ch_ff_tr) f10
  (ch_ff_hi) f1   (ch_ff_hm) f3   (ch_ff_hr) f5

  ;;                  | | | | |     --     | | | | |
  ;;                  | | |*|*|     --     |*|*| | |
  (ch_ff_hi  ch_ff_hm) f2

  ;;                  | | | | |     --     | | | | |
  ;;                  | |*|*| |     --     | |*|*| |
  (ch_ff_hm  ch_ff_hr) f4

  ;;                  | | |*|*|     --     |*|*| | |
  ;;                  | | | | |     --     | | | | |
  (ch_ff_ti  ch_ff_tm) f7

  ;;                  | |*|*| |     --     | |*|*| |
  ;;                  | | | | |     --     | | | | |
  (ch_ff_tm  ch_ff_tr) f9
)

(defchords CH_NA $chord_timeout
  ;; NAVIGATION CHORDS
  (ch_tab) tab   (ch_up) up     (ch_bspc) bspc
  (ch_lt) left   (ch_dn) down   (ch_rt) rght

  ;;                  | | | | |     --     | | | | |
  ;;                  | |*|*|*|     --     |*|*|*| |
  (ch_lt ch_dn ch_rt) spc

  ;;                  | |*|*|*|     --     |*|*|*| |
  ;;                  | | | | |     --     | | | | |
  (ch_tab ch_up ch_bspc) esc

  ;;                  | |*| |*|     --     |*| |*| |
  ;;                  | | | | |     --     | | | | |
  (ch_tab ch_bspc) home

  ;;                  | | | | |     --     | | | | |
  ;;                  | |*| |*|     --     |*| |*| |
  (ch_lt ch_rt) end

  ;;                  | |*|*| |     --     | |*|*| |
  ;;                  | | | | |     --     | | | | |
  (ch_up  ch_bspc) del

  ;;                  | | |*|*|     --     |*|*| | |
  ;;                  | | | | |     --     | | | | |
  ;;(ch_tab  ch_up) ???

  ;;                  | |*| | |     --     | | |*| |
  ;;                  | | |*| |     --     | |*| | |
  ;;(ch_dn  ch_bspc) ???
)

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;; LAYERS ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

;; Chords: "g + h" switchs to "L_NO_MODS" (same layer with no modifiers - same combo to switch back)
(deflayermap (L_ALPHA)
  caps @esc_sft

  ;; LEFT
  q @al_tpl    w @al_trl     e @al_tml     r @al_til
  a @al_hpl    s @al_hrl     d @al_hml     f @al_hil    g @al_sil
  z @al_bpl    x @al_brl     c @al_bml     v @al_bil

  ;; RIGHT
               u @al_tir    i @al_tmr     o @al_trr     p @al_tpr
  h @al_sir    j @al_hir    k @al_hmr     l @al_hrr     ; @al_hpr
               m @al_bir    , @al_bmr     . @al_brr     / @al_bpr
)

;; Layer: no modifiers (ideal for gaming)
;; Chords: "g + h" to switch to "L_ALPHA"
(deflayermap (L_NO_MODS)
  caps @esc_sft

  ;; LEFT
                  q q     w w     e e     r r
                  a z     s s     d d     f f    g @ch_no_sil
                  z XX    x XX    c XX    v XX

  ;; RIGHT
                  u u     i i     o o     p p
  h @ch_no_sir    j j     k k     l l     ; ;
                  m XX    , XX    . XX    / XX
)

;; Layer: Navigation layer with modifiers and chords
(deflayermap (L_NAV_R)
  ;; LEFT
          q @sw_nav_l    w lalt    e tab    r @na_pgup
          a @os_go       s lctl    d esc    f @na_pgdn    g XX
          z XX           x XX      c XX     v XX

  ;; RIGHT
          u @ch_na_tab    i @ch_na_up    o @ch_na_bspc    p @sw_al
  h XX    j @ch_na_lt     k @ch_na_dn    l @ch_na_rt      ; enter
          m XX            , XX           . XX             / XX
)

;; Layer: The reverse of RIGHT
(deflayermap (L_NAV_L)
  ;; LEFT
          q @sw_al    w @ch_na_bspc    e @ch_na_up    r @ch_na_tab
          a enter     s @ch_na_lt      d @ch_na_dn    f @ch_na_rt    g XX
          z XX        x XX             c XX           v XX

  ;; RIGHT
          u @na_pgup    i tab    o lalt    p @sw_nav_r
  h XX    j @na_pgdn    k esc    l lctl    ; @os_go
          m XX          , XX     . XX      / XX
)

(deflayermap (L_NUMS)
  ;; LEFT
              q @ns_tp     w @ns_tr    e @ns_tm    r @ns_ti
              a @ns_hpl    s @ns_hr    d @ns_hm    f @ns_hi    g @ns_si
              z XX         x XX        c @ns_bm    v @ns_bi

  ;; RIGHT
              u @ns_ti    i @ns_tm    o @ns_tr    p @ns_tp
  h @ns_si    j @ns_hi    k @ns_hm    l @ns_hr    ; @ns_hpr
              m @ns_bi    , @ns_bm    . XX        / XX
)

(deflayermap (L_FF)
  ;; LEFT
          q f11    w @ff_tr    e @ff_tm     r @ff_ti
          a f23    s @ff_hr    d @ff_hm     f @ff_hi    g XX
          z XX     x XX        c XX         v XX

  ;; RIGHT
          u @ff_ti    i @ff_tm    o @ff_tr    p f11
  h XX    j @ff_hi    k @ff_hm    l @ff_hr    ; f12
          m XX        , XX        . XX        / XX
)

(deflayermap (L_MEDIA) ;;
  ;; LEFT
          q brup     w prev   e volu      r mute
          a brdwn    s next   d voldwn    f pp      g XX
          z XX       x XX     c XX        v XX

  ;; RIGHT
          u mute    i volu     o prev    p brup
  h XX    j pp      k voldwn   l next    ; brdwn
          m XX      , XX       . XX      / XX
)

(deflayermap (L_GO) ;; Go-to shortcuts
  ;; LEFT
          q @alt_9    w @alt_grv    e @ctl_pgup    r @ctl_sft_t
          a @alt_1    s @ctl_tab    d @ctl_pgdn    f @ctl_w        g XX
          z XX        x XX          c XX           v XX

  ;; RIGHT
          u @ctl_sft_t    i @ctl_pgup    o @alt_grv    p @alt_9
  h XX    j @ctl_w        k @ctl_pgdn    l @ctl_tab    ; @alt_1
          m XX            , XX           . XX          / XX
)

