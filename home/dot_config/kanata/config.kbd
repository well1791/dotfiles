  ;;                   | | | | |    --     | | | | |
  ;;                   |*| | | |    --     | | | |*|
  ;;                       | |*|    --     |*| |
  (ch_bil ch_hpl) @os_alt                  (ch_bir ch_hpr) @os_alt

  ;;                   | | | | |    --     | | | | |
