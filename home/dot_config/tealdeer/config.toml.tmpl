# tealdeer configuration
# See: https://tealdeer-rs.github.io/tealdeer/config.html

[display]
compact = false
use_pager = true
show_title = true

[style.command_name]
foreground = "blue"
bold = true

[style.example_text]
foreground = "green"

[style.example_code]
foreground = "cyan"
bold = true

[style.example_variable]
foreground = "yellow"
underline = true

[updates]
auto_update = true
auto_update_interval_hours = 336  # 2 weeks
