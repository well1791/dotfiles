{{ template "install-header.sh.tmpl" . }}
# Install espanso (text expander)
# https://espanso.org

# Skip if already installed
if log_version espanso; then
    exit 0
fi

# Detect display server (X11 or Wayland)
DISPLAY_SERVER="${XDG_SESSION_TYPE:-x11}"
log_info "Detected display server: $DISPLAY_SERVER"

# Require AUR helper (Arch-based only)
AUR_HELPER=""
if check_command paru; then
    AUR_HELPER="paru"
elif check_command yay; then
    AUR_HELPER="yay"
else
    die "No AUR helper found (paru or yay required for CachyOS/Arch)"
fi

# Install appropriate package based on display server
if [ "$DISPLAY_SERVER" = "wayland" ]; then
    log_info "Installing espanso-wayland from AUR..."
    if ! is_dry_run; then
        $AUR_HELPER -S --needed --noconfirm espanso-wayland
    else
        log_info "[DRY RUN] Would run: $AUR_HELPER -S --needed --noconfirm espanso-wayland"
    fi
else
    log_info "Installing espanso (X11) from AUR..."
    if ! is_dry_run; then
        $AUR_HELPER -S --needed --noconfirm espanso
    else
        log_info "[DRY RUN] Would run: $AUR_HELPER -S --needed --noconfirm espanso"
    fi
fi

# Verify
if ! check_command espanso; then
    die "espanso installation failed"
fi

log_success "espanso installed" "$(get_version espanso)"

# Set required capabilities for Wayland
if [ "$DISPLAY_SERVER" = "wayland" ]; then
    log_info "Setting required capabilities for Wayland..."
    run_privileged setcap "cap_dac_override+p" "$(which espanso)"
    log_success "Capabilities set"
fi

# Register systemd service
log_info "Registering espanso systemd service..."
if ! is_dry_run; then
    espanso service register || log_warn "Service registration failed (may already be registered)"
fi

log_success "espanso setup complete!"
log_info "  To start: espanso start"
log_info "  To edit config: espanso edit"
if [ "$DISPLAY_SERVER" = "wayland" ]; then
    log_info "  Note: On Wayland, non-US keyboard layouts need explicit configuration"
fi
