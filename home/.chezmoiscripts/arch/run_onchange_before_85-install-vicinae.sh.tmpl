{{ template "install-header.sh.tmpl" . }}
# Install vicinae (keyboard-driven application launcher)
# https://docs.vicinae.com

# Skip if already installed
if check_command vicinae; then
    log_success "vicinae already installed"
    exit 0
fi

# Require AUR helper
AUR_HELPER=""
if check_command paru; then
    AUR_HELPER="paru"
elif check_command yay; then
    AUR_HELPER="yay"
else
    die "No AUR helper found (paru or yay required for CachyOS/Arch)"
fi

# Install vicinae-bin from AUR
log_info "Installing vicinae-bin from AUR..."
if ! is_dry_run; then
    $AUR_HELPER -S --needed --noconfirm vicinae-bin
else
    log_info "[DRY RUN] Would run: $AUR_HELPER -S --needed --noconfirm vicinae-bin"
fi

# Verify
if ! check_command vicinae; then
    die "vicinae installation failed"
fi

log_success "vicinae installed"

# Enable systemd service
log_info "Enabling vicinae systemd service..."
if ! is_dry_run; then
    systemctl --user enable --now vicinae.service
fi
log_success "vicinae service enabled"

log_success "vicinae setup complete!"
log_info "  Toggle launcher: Super+Space"
log_info "  Open settings: vicinae settings"
log_info "  Config: ~/.config/vicinae/"
