{{ template "install-header.sh.tmpl" . }}
# Install glimpseui dependencies (GTK4, WebKit, layer-shell)
# https://github.com/user/glimpseui

PACKAGES="gtk4 webkitgtk-6.0 gtk4-layer-shell"

# Check which packages are missing
MISSING=""
for pkg in $PACKAGES; do
    if ! pacman -Qi "$pkg" >/dev/null 2>&1; then
        MISSING="$MISSING $pkg"
    fi
done

if [ -z "$MISSING" ]; then
    log_success "All glimpseui dependencies already installed"
    exit 0
fi

log_info "Installing glimpseui dependencies:$MISSING"
install_packages $MISSING

# Verify
for pkg in $PACKAGES; do
    if pacman -Qi "$pkg" >/dev/null 2>&1; then
        log_success "$pkg installed"
    else
        log_error "$pkg: installation failed"
    fi
done
