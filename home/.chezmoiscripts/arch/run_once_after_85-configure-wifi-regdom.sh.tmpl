{{ template "install-header.sh.tmpl" . }}
# Configure Wi-Fi regulatory domain for Spain (ES)
# See: https://wiki.archlinux.org/title/Wireless_network_configuration#Respecting_the_regulatory_domain

log_info "Wi-Fi Regulatory Domain Configuration"

# Install wireless-regdb package if missing
if check_command pacman; then
    if ! pacman -Qi wireless-regdb >/dev/null 2>&1; then
        log_info "Installing wireless-regdb..."
        install_packages wireless-regdb
    fi
fi

# Check current setting
CURRENT_REGDOM=""
if [ -f /etc/conf.d/wireless-regdom ]; then
    CURRENT_REGDOM=$(grep '^WIRELESS_REGDOM=' /etc/conf.d/wireless-regdom 2>/dev/null || true)
fi

if echo "$CURRENT_REGDOM" | grep -q 'WIRELESS_REGDOM="ES"'; then
    log_success "Wi-Fi regulatory domain already set to ES (Spain)"
    iw reg get 2>/dev/null || true
    exit 0
fi

log_warn "MANUAL CONFIGURATION REQUIRED"
echo ""
echo "Country: Spain (ES)"
echo ""
echo "To configure Wi-Fi regulatory domain:"
echo ""
echo "1. Edit the configuration file:"
echo "   sudo micro /etc/conf.d/wireless-regdom"
echo ""
echo "2. Find and uncomment this line:"
echo '   WIRELESS_REGDOM="ES"'
echo ""
echo "3. Reboot to apply changes"
echo ""
echo "4. Verify after reboot:"
echo "   iw reg get"
echo ""
log_info "Benefits:"
log_info "  - Unlock all Wi-Fi channels available in Spain"
log_info "  - Enable full 5GHz/6GHz spectrum (Wi-Fi 6E)"
log_info "  - Optimize transmit power for EU regulations"
echo ""
log_info "Current status:"
iw reg get 2>/dev/null || log_info "  (Unable to query current regulatory domain)"
