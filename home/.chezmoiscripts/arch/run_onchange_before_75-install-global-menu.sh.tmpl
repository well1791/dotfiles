{{ template "install-header.sh.tmpl" . }}
# Install global menu support for GTK applications
# Required for proper integration with KDE Plasma global menu

# Check if packages are already installed (Arch-specific check)
if check_command pacman; then
    if pacman -Qi appmenu-gtk-module >/dev/null 2>&1 && \
       pacman -Qi libdbusmenu-glib >/dev/null 2>&1; then
        log_success "Global menu packages already installed"
        exit 0
    fi
fi

log_info "Installing global menu support..."
install_packages appmenu-gtk-module libdbusmenu-glib

log_success "Global menu support installed"
log_info "  Restart affected GTK applications to see global menu integration"
