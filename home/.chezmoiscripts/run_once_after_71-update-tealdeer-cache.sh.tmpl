{{ template "install-header.sh.tmpl" . }}
# Update tealdeer (tldr) cache
# This should run after tealdeer is installed

# Check if tealdeer is installed
if ! check_command tldr; then
    log_warn "tealdeer not installed, skipping cache update"
    exit 0
fi

# Update cache
if [ -d "$HOME/.cache/tealdeer" ] && [ -n "$(ls -A "$HOME/.cache/tealdeer" 2>/dev/null)" ]; then
    log_info "Updating tealdeer cache..."
else
    log_info "Populating tealdeer cache for the first time..."
fi

if ! is_dry_run; then
    tldr --update
fi

log_success "tealdeer ready to use"
log_info "  Try: tldr tar"
log_info "  Try: tldr git commit"
