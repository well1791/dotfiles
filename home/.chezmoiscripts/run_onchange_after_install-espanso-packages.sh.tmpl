{{ template "install-header.sh.tmpl" . }}
# Install espanso packages from packages.txt
# This runs whenever packages.txt changes
# packages.txt hash: {{ include "dot_config/espanso/packages.txt" | sha256sum }}

# Check if espanso is installed
if ! check_command espanso; then
    log_warn "espanso not installed, skipping package installation"
    exit 0
fi

PACKAGES_FILE="$HOME/.config/espanso/packages.txt"

if [ ! -f "$PACKAGES_FILE" ]; then
    log_warn "No packages.txt found at $PACKAGES_FILE"
    exit 0
fi

# Read packages.txt and install each package
log_info "Installing espanso packages from packages.txt..."
INSTALLED=0
SKIPPED=0

while IFS= read -r line; do
    # Skip empty lines and comments
    case "$line" in
        ''|'#'*) continue ;;
    esac

    # Extract package name (remove trailing comments)
    package=$(echo "$line" | cut -d'#' -f1 | xargs)

    if [ -n "$package" ]; then
        log_info "Installing: $package"
        if is_dry_run; then
            log_info "[DRY RUN] Would install espanso package: $package"
            INSTALLED=$((INSTALLED + 1))
        elif espanso install "$package" --force; then
            INSTALLED=$((INSTALLED + 1))
        else
            log_warn "Failed to install: $package"
            SKIPPED=$((SKIPPED + 1))
        fi
    fi
done < "$PACKAGES_FILE"

log_success "Installed: $INSTALLED packages"
if [ $SKIPPED -gt 0 ]; then
    log_warn "Skipped/Failed: $SKIPPED packages"
fi
