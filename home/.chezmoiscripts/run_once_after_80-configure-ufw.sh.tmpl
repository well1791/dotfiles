{{ template "install-header.sh.tmpl" . }}
# Install and enable ufw firewall
# Configured for web development (localhost unaffected)

# Install ufw if not present
if ! check_command ufw; then
    log_info "Installing ufw..."
    install_packages ufw
fi

# Check if already enabled
if sudo ufw status 2>/dev/null | grep -q "Status: active"; then
    log_success "ufw already enabled"
    sudo ufw status verbose
    exit 0
fi

log_info "Configuring ufw firewall..."

if is_dry_run; then
    log_info "[DRY RUN] Would configure ufw: deny incoming, allow outgoing"
    log_info "[DRY RUN] Would enable ufw and systemd service"
    exit 0
fi

# Basic configuration
run_privileged ufw default deny incoming
run_privileged ufw default allow outgoing

# Enable firewall
run_privileged ufw --force enable

# Enable ufw service to start on boot
run_privileged systemctl enable ufw.service

log_success "ufw enabled and configured"
echo ""
echo "Firewall Status:"
sudo ufw status verbose
echo ""
log_info "Notes:"
log_info "  - localhost/127.0.0.1 is UNAFFECTED (local dev servers work normally)"
log_info "  - All outgoing connections are ALLOWED"
log_info "  - Incoming connections from outside are DENIED by default"
echo ""
log_info "Network Access to Dev Servers:"
echo "  sudo ufw allow from 192.168.0.0/16 to any port 3000:9999 proto tcp"
echo ""
log_info "Common Commands:"
echo "  Check status:        sudo ufw status verbose"
echo "  Allow port:          sudo ufw allow <port>"
echo "  Disable firewall:    sudo ufw disable"
