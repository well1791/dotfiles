{{ template "install-header.sh.tmpl" . }}
# Install Rust via rustup
# https://rustup.rs

# Skip if rustup already installed
if check_command rustup; then
    log_success "rustup already installed" "$(get_version rustup)"
    exit 0
fi

# Detect system rust without rustup (conflict)
if check_command cargo && ! check_command rustup; then
    log_warn "Rust is installed but not via rustup"
    log_info "  Consider uninstalling system rust and using rustup instead"
    log_info "  Skipping rustup installation to avoid conflicts"
    exit 0
fi

# Install via rustup
require_command curl "curl is required to install rustup"
log_info "Installing Rust via rustup..."

if is_dry_run; then
    log_info "[DRY RUN] Would run: curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y"
else
    curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y
fi

# Verify
if [ -f "$HOME/.cargo/env" ]; then
    . "$HOME/.cargo/env"
    if check_command rustup; then
        log_success "Rust installed successfully"
        log_info "  rustup: $(get_version rustup)"
        log_info "  rustc: $(get_version rustc)"
        log_info "  cargo: $(get_version cargo)"
        log_warn "Restart your shell or run: source ~/.cargo/env"
    else
        log_warn "Installation completed but rustup command not found"
        log_info "  You may need to add ~/.cargo/bin to your PATH"
    fi
else
    die "Installation failed: ~/.cargo/env not found"
fi
