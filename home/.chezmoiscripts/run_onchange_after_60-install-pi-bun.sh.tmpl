{{ template "install-header.sh.tmpl" . }}
# Install pi coding agent via bun
# https://pi.dev

# Skip if already installed
if log_version pi; then
    exit 0
fi

# Requires bun
if ! check_command bun; then
    log_warn "bun not found, skipping pi installation"
    log_info "  pi requires bun to be installed first"
    exit 0
fi

# Install pi globally
log_info "Installing pi coding agent via bun..."
if is_dry_run; then
    log_info "[DRY RUN] Would run: bun install -g @anthropic-ai/claude-code"
else
    if bun install -g @anthropic-ai/claude-code; then
        if check_command pi; then
            log_success "pi installed successfully" "$(get_version pi)"
        else
            log_warn "pi installed but not found in PATH"
            log_info "  You may need to add ~/.bun/bin to your PATH"
        fi
    else
        die "Failed to install pi"
    fi
fi
