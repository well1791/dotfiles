{{ template "install-header.sh.tmpl" . }}
# Install atuin (magical shell history)
# https://atuin.sh/

# Skip if already installed
if log_version atuin; then
    exit 0
fi

log_info "Installing atuin..."

# Install based on OS family
OS_FAMILY=$(get_os_family)
case "$OS_FAMILY" in
    arch)
        install_packages atuin
        ;;
    debian)
        log_info "atuin not in default Ubuntu repos, using shell installer..."
        require_command curl "curl is required to install atuin"
        if is_dry_run; then
            log_info "[DRY RUN] Would run: curl --proto '=https' --tlsv1.2 -LsSf https://setup.atuin.sh | sh -s -- --non-interactive"
        else
            curl --proto '=https' --tlsv1.2 -LsSf https://setup.atuin.sh | sh -s -- --non-interactive
        fi
        ;;
    rhel)
        install_packages atuin || {
            log_info "atuin not in default repos, using shell installer..."
            require_command curl "curl is required to install atuin"
            if ! is_dry_run; then
                curl --proto '=https' --tlsv1.2 -LsSf https://setup.atuin.sh | sh -s -- --non-interactive
            fi
        }
        ;;
    *)
        log_info "Using shell script installer..."
        require_command curl "curl is required to install atuin"
        if is_dry_run; then
            log_info "[DRY RUN] Would run atuin shell installer"
        else
            curl --proto '=https' --tlsv1.2 -LsSf https://setup.atuin.sh | sh -s -- --non-interactive
        fi
        ;;
esac

# Verify
if check_command atuin; then
    log_success "atuin installed successfully" "$(get_version atuin)"
    log_info "Note: Fish shell integration will be added to your config.fish"
else
    die "atuin installation failed"
fi
