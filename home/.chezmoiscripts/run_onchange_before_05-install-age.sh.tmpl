{{ template "install-header.sh.tmpl" . }}
# Install age (simple, modern encryption tool)
# https://github.com/FiloSottile/age

# Skip if already installed
if log_version age; then
    exit 0
fi

# Install via system package manager
log_info "Installing age..."
install_packages age

# Verify
if check_command age; then
    log_success "age installed successfully" "$(get_version age)"
else
    log_warn "age installation may have failed. Check logs above."
fi
