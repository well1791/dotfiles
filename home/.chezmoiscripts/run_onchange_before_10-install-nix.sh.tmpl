{{ template "install-header.sh.tmpl" . }}
# Install Nix package manager (Determinate Systems installer)
# https://github.com/DeterminateSystems/nix-installer

# Skip if already installed
if log_version nix; then
    exit 0
fi

# Install via Determinate Systems installer
require_any_command "curl or wget required to install Nix" curl wget
download_and_run "https://install.determinate.systems/nix" "Installing Nix..."

# Verify
if check_command nix; then
    log_success "Nix installed successfully" "$(get_version nix)"
    log_warn "Restart your shell or run: source /nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh"
else
    log_warn "Nix installed but not in PATH yet. Restart your shell."
fi
