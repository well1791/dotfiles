{{ template "install-header.sh.tmpl" . }}
# Install devenv (declarative developer environments)
# https://devenv.sh
# Requires: Nix package manager

# Skip if already installed
if check_command devenv; then
    log_success "devenv already installed" "$(devenv version 2>&1 | head -1)"
    exit 0
fi

# Check for Nix dependency
if ! check_command nix; then
    log_warn "devenv requires Nix. Skipping devenv installation."
    log_info "  Nix should have been installed by the previous script."
    log_info "  If installation failed, restart your shell and run 'chezmoi apply' again."
    exit 0
fi

# Install via official installer
require_any_command "curl or wget required to install devenv" curl wget
download_and_run "https://devenv.sh/install.sh" "Installing devenv..."

# Verify
if check_command devenv; then
    log_success "devenv installed successfully" "$(devenv version 2>&1 | head -1)"
else
    log_warn "devenv installed but may not be in PATH yet. Restart your shell."
fi
