{{ template "install-header.sh.tmpl" . }}
# Install Bun (fast all-in-one JavaScript runtime)
# https://bun.sh

# Skip if already installed
if log_version bun; then
    exit 0
fi

# Ensure unzip dependency is available
if ! check_command unzip; then
    log_info "Installing required dependency: unzip"
    install_packages unzip
fi

# Install via official installer
require_any_command "curl or wget required to install bun" curl wget
download_and_run "https://bun.sh/install" "Installing bun..."

# Verify
if [ -x "$HOME/.bun/bin/bun" ]; then
    log_success "bun installed successfully" "$("$HOME/.bun/bin/bun" --version 2>&1 | head -1)"
    log_warn "Restart your shell or run: export PATH=\"\$HOME/.bun/bin:\$PATH\""
else
    log_warn "bun installation may have failed. Check logs above."
fi
