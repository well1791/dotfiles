{{ template "install-header.sh.tmpl" . }}
# Install uv (fast Python package manager)
# https://github.com/astral-sh/uv

# Skip if already installed
if log_version uv; then
    exit 0
fi

# Install via official installer
require_any_command "curl or wget required to install uv" curl wget
download_and_run "https://astral.sh/uv/install.sh" "Installing uv..."

# Verify
if check_command uv; then
    log_success "uv installed successfully" "$(get_version uv)"
else
    log_warn "uv installed but not in PATH yet. Restart your shell or run:"
    echo '  export PATH="$HOME/.local/bin:$PATH"'
fi
