{{ template "install-header.sh.tmpl" . }}
# Install mise (polyglot runtime manager)
# https://mise.jdx.dev

# Skip if already installed
if log_version mise; then
    exit 0
fi

# Install via official installer
require_any_command "curl or wget required to install mise" curl wget
download_and_run "https://mise.jdx.dev/install.sh" "Installing mise..."

# Verify
if check_command mise; then
    log_success "mise installed successfully" "$(get_version mise)"
else
    log_warn "mise installed but not in PATH yet. Restart your shell or run:"
    echo '  export PATH="$HOME/.local/bin:$PATH"'
fi
