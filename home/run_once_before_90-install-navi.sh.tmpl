{{ template "install-header.sh.tmpl" . }}
# Install navi (interactive cheatsheet tool)
# https://github.com/denisidoro/navi

# Skip if already installed
if log_version navi; then
    exit 0
fi

# Require AUR helper
AUR_HELPER=""
if check_command paru; then
    AUR_HELPER="paru"
elif check_command yay; then
    AUR_HELPER="yay"
else
    die "No AUR helper found (paru or yay required for CachyOS/Arch)"
fi

# Install navi
log_info "Installing navi..."
if ! is_dry_run; then
    $AUR_HELPER -S --needed --noconfirm navi
else
    log_info "[DRY RUN] Would run: $AUR_HELPER -S --needed --noconfirm navi"
fi

# Verify
if ! check_command navi; then
    die "navi installation failed"
fi

log_success "navi installed" "$(get_version navi)"
log_info "  Usage: navi (interactive mode)"
log_info "  Fish widget: Ctrl+G"
log_info "  Config: ~/.config/navi/config.yaml"
log_info "  Cheats: ~/.local/share/navi/cheats/"
