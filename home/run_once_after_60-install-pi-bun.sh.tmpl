#!/bin/sh
# Install pi coding agent via bun
# https://pi.dev

set -e

# Check if pi is already installed
if command -v pi >/dev/null 2>&1; then
    echo "✓ pi already installed ($(pi --version 2>&1 | head -1))"
    exit 0
fi

# Check if bun is available
if ! command -v bun >/dev/null 2>&1; then
    echo "⚠ bun not found, skipping pi installation"
    echo "  pi requires bun to be installed first"
    exit 0
fi

echo "Installing pi coding agent via bun..."

# Install pi globally using bun
if bun install -g @earendil-works/pi-coding-agent; then
    # Verify installation
    if command -v pi >/dev/null 2>&1; then
        echo "✓ pi installed successfully: $(pi --version 2>&1 | head -1)"
    else
        echo "⚠ pi installed but not found in PATH"
        echo "  You may need to add ~/.bun/bin to your PATH"
    fi
else
    echo "✗ Failed to install pi"
    exit 1
fi
