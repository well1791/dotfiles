{{ template "install-header.sh.tmpl" . }}
# Install/update zellij plugins when manifest changes
# plugins.toml hash: {{ include "dot_config/zellij/plugins.toml" | sha256sum }}

PLUGIN_SCRIPT="{{ .chezmoi.homeDir }}/.config/zellij/scripts/install-plugins.sh"

if [ ! -f "$PLUGIN_SCRIPT" ]; then
    log_warn "Plugin install script not found: $PLUGIN_SCRIPT"
    exit 0
fi

# Make executable if needed
chmod +x "$PLUGIN_SCRIPT"

# Run install script
log_info "Zellij plugin manifest changed, updating plugins..."
if is_dry_run; then
    log_info "[DRY RUN] Would run: $PLUGIN_SCRIPT --force"
else
    "$PLUGIN_SCRIPT" --force
fi
