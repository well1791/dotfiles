#!/bin/sh
# Chezmoi hook: Install/update zellij plugins when manifest changes
#
# This script runs automatically when plugins.toml changes.
# The hash ensures it only runs when the manifest is modified.
#
# plugins.toml hash: {{ include "dot_config/zellij/plugins.toml" | sha256sum }}

set -e

PLUGIN_SCRIPT="{{ .chezmoi.homeDir }}/.config/zellij/scripts/install-plugins.sh"

if [ ! -f "$PLUGIN_SCRIPT" ]; then
    echo "Warning: Plugin install script not found: $PLUGIN_SCRIPT" >&2
    exit 0
fi

# Make executable if needed
chmod +x "$PLUGIN_SCRIPT"

# Run install script
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "Zellij plugin manifest changed, updating plugins..."
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
"$PLUGIN_SCRIPT" --force
