#!/bin/sh
# Install Nix package manager using Determinate Systems installer
# https://github.com/DeterminateSystems/nix-installer

set -e

# Check if Nix is already installed
if command -v nix >/dev/null 2>&1; then
    echo "✓ Nix already installed ($(nix --version 2>&1 | head -1))"
    exit 0
fi

echo "Installing Nix (Determinate Systems installer)..."

# Install Nix using the Determinate Systems installer
# This is more robust than the official installer and handles macOS upgrades better
if command -v curl >/dev/null 2>&1; then
    curl --proto '=https' --tlsv1.2 -sSf -L https://install.determinate.systems/nix | sh -s -- install
elif command -v wget >/dev/null 2>&1; then
    wget -qO- https://install.determinate.systems/nix | sh -s -- install
else
    echo "Error: curl or wget is required to install Nix" >&2
    exit 1
fi

# Verify installation
if command -v nix >/dev/null 2>&1; then
    echo "✓ Nix installed successfully ($(nix --version 2>&1 | head -1))"
    echo "⚠ You may need to restart your shell or run: source /nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh"
else
    echo "⚠ Nix installed but not in PATH yet. Restart your shell."
fi
