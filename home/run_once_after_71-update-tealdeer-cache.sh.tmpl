#!/bin/sh
# Update tealdeer (tldr) cache
# This should run after tealdeer is installed

set -e

# Check if tealdeer is installed
if ! command -v tldr >/dev/null 2>&1; then
    echo "⚠ tealdeer not installed, skipping cache update"
    exit 0
fi

# Check if cache is already populated
if [ -d "$HOME/.cache/tealdeer" ] && [ -n "$(ls -A "$HOME/.cache/tealdeer" 2>/dev/null)" ]; then
    echo "✓ tealdeer cache already populated, updating..."
    tldr --update
else
    echo "Populating tealdeer cache for the first time..."
    tldr --update
fi

echo ""
echo "✓ tealdeer ready to use"
echo "  Try: tldr tar"
echo "  Try: tldr git commit"
echo "  Try: tldr rsync"
