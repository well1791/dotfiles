{{ template "install-header.sh.tmpl" . }}
# Install engram (persistent memory for AI agents)
# https://github.com/Gentleman-Programming/engram

# Skip if already installed
if check_command engram; then
    log_success "engram already installed" "$(engram version 2>&1 | head -1)"
    exit 0
fi

# Detect architecture
ARCH=$(uname -m)
case "$ARCH" in
    x86_64)
        ARCH_NAME="amd64"
        ;;
    aarch64|arm64)
        ARCH_NAME="arm64"
        ;;
    *)
        log_warn "Unsupported architecture: $ARCH"
        log_info "  Please install engram manually: https://github.com/Gentleman-Programming/engram"
        exit 0
        ;;
esac

# Check dependencies
require_any_command "curl or wget required to install engram" curl wget
require_command tar "tar is required to install engram"

# Fetch latest version from GitHub API
log_info "Fetching latest engram version..."
LATEST_VERSION=$(fetch_url "https://api.github.com/repos/Gentleman-Programming/engram/releases/latest" | grep '"tag_name"' | sed -E 's/.*"([^"]+)".*/\1/')

if [ -z "$LATEST_VERSION" ]; then
    log_warn "Could not fetch latest version. Using v1.15.15 as fallback."
    LATEST_VERSION="v1.15.15"
fi

VERSION_NUM=$(echo "$LATEST_VERSION" | sed 's/^v//')
DOWNLOAD_URL="https://github.com/Gentleman-Programming/engram/releases/download/${LATEST_VERSION}/engram_${VERSION_NUM}_linux_${ARCH_NAME}.tar.gz"

log_info "Downloading engram ${LATEST_VERSION} for linux_${ARCH_NAME}..."

if is_dry_run; then
    log_info "[DRY RUN] Would download: $DOWNLOAD_URL"
    log_info "[DRY RUN] Would install to: ~/.local/bin/engram"
    exit 0
fi

# Download and extract
TMP_DIR=$(mktemp -d)
trap 'rm -rf "$TMP_DIR"' EXIT

fetch_url "$DOWNLOAD_URL" "$TMP_DIR/engram.tar.gz"
cd "$TMP_DIR"
tar -xzf engram.tar.gz

# Install to ~/.local/bin
mkdir -p "$HOME/.local/bin"
if [ -f "engram" ]; then
    mv engram "$HOME/.local/bin/engram"
    chmod +x "$HOME/.local/bin/engram"
else
    die "Could not find engram binary in archive"
fi

# Verify
if check_command engram; then
    log_success "engram installed successfully" "$(engram version 2>&1 | head -1)"
else
    log_warn "engram installed to ~/.local/bin/engram but not in PATH yet."
    log_info "  Restart your shell or ensure ~/.local/bin is in your PATH"
fi
