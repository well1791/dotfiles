{{ template "install-header.sh.tmpl" . }}
# Install podman (daemonless container engine)
# https://podman.io

# Skip if already installed
if log_version podman; then
    exit 0
fi

# Install via system package manager
log_info "Installing podman..."
install_packages podman

# Verify
if check_command podman; then
    log_success "podman installed successfully" "$(get_version podman)"

    # Check rootless mode support
    if [ -f /proc/sys/kernel/unprivileged_userns_clone ]; then
        if [ "$(cat /proc/sys/kernel/unprivileged_userns_clone)" = "0" ]; then
            log_warn "Rootless mode requires user namespaces. Run:"
            echo "  echo 'kernel.unprivileged_userns_clone=1' | sudo tee /etc/sysctl.d/99-rootless.conf"
            echo "  sudo sysctl --system"
        fi
    fi
else
    log_warn "podman installation may have failed. Check logs above."
fi
