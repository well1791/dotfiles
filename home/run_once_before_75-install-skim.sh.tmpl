{{ template "install-header.sh.tmpl" . }}
# Install skim (fuzzy finder in Rust)
# https://github.com/skim-rs/skim

# Skip if already installed
if check_command sk; then
    log_success "skim already installed" "$(sk --version)"
    exit 0
fi

# Requires cargo
if ! check_command cargo; then
    log_warn "cargo is required to install skim"
    log_info "  Install Rust first: https://rustup.rs"
    exit 1
fi

# Update toolchain if rustup is available (skim requires recent rustc)
if check_command rustup; then
    log_info "Updating Rust toolchain to ensure compatibility..."
    if ! is_dry_run; then
        rustup update stable
        rustup default stable
    fi
    log_info "Current rustc version: $(get_version rustc)"
fi

# Install via cargo
log_info "Installing skim via cargo..."
if is_dry_run; then
    log_info "[DRY RUN] Would run: cargo install skim"
else
    cargo install skim
fi

# Verify
if check_command sk; then
    log_success "skim installed successfully" "$(sk --version)"
else
    log_warn "skim installed but not in PATH yet. Restart your shell or run:"
    echo "  source ~/.cargo/env"
fi
